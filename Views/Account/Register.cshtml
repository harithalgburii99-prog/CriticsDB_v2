@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <i class="fas fa-film"></i>
            CRITICS<span class="brand-accent">DB</span>
        </div>
        <h2 class="auth-title">Join CriticsDB</h2>
        <p class="auth-subtitle">Start rating and reviewing movies today</p>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="DisplayName">Display Name</label>
                <div class="input-icon-wrap">
                    <i class="fas fa-user input-icon"></i>
                    <input asp-for="DisplayName" class="form-input" placeholder="Your critic name" />
                </div>
                <span asp-validation-for="DisplayName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <div class="input-icon-wrap">
                    <i class="fas fa-envelope input-icon"></i>
                    <input asp-for="Email" class="form-input" placeholder="you@example.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-icon-wrap">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="Password" class="form-input" placeholder="Min 6 characters" autocomplete="new-password" />
                    <button type="button" class="toggle-password" onclick="togglePassword(this)">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <div class="input-icon-wrap">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="ConfirmPassword" class="form-input" placeholder="Repeat password" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-auth">Create Account</button>
        </form>

        <div class="auth-divider"><span>Already a member?</span></div>
        <a asp-action="Login" class="btn-auth-outline">Sign In</a>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(btn) {
            const input = btn.previousElementSibling;
            input.type = input.type === 'password' ? 'text' : 'password';
            btn.querySelector('i').className = input.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
        }
    </script>
}
