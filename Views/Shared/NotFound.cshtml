@{
    ViewData["Title"] = "Page Not Found";
}

<div class="error-page">
    <div class="error-content">
        <div class="error-code">404</div>
        <h1 class="error-title">Scene Not Found</h1>
        <p class="error-subtitle">Looks like this page was cut from the final edit.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-primary-lg">
            <i class="fas fa-home"></i> Back to Home
        </a>
    </div>
</div>

<style>
.error-page {
    min-height: calc(100vh - var(--nav-h));
    display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 40px;
    background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(232,197,71,0.04) 0%, transparent 70%);
}
.error-code {
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 12rem);
    color: var(--accent); opacity: 0.3;
    line-height: 1; margin-bottom: 16px;
}
.error-title { font-size: 2rem; font-weight: 700; margin-bottom: 12px; }
.error-subtitle { color: var(--text-secondary); margin-bottom: 32px; font-size: 1.1rem; }
</style>
