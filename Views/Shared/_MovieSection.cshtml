@{
    var title = ViewData["Title"]?.ToString() ?? "";
    var icon = ViewData["Icon"]?.ToString() ?? "film";
    var movies = ViewData["Movies"] as List<MovieListViewModel> ?? new();
}

<section class="movie-section">
    <div class="section-header">
        <h2 class="section-title"><i class="fas fa-@icon"></i> @title</h2>
        <a asp-controller="Movies" asp-action="Index" class="section-link">View All <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="movie-grid">
        @foreach (var m in movies)
        {
            <partial name="_MovieCard" model="m" />
        }
    </div>
</section>
